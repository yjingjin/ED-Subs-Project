# --- Data: never commit raw/exported data (PHI/PII risk) ---
data/
!data/exports/.gitkeep
*.csv
*.parquet
*.tsv
*.xlsx

# --- Secrets / config ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# --- Notebooks ---
.ipynb_checkpoints/

# --- ML / experiment tracking ---
mlruns/
mlartifacts/

# --- IDE ---
.idea/
.vscode/
*.iml

# --- OS ---
.DS_Store
Thumbs.db

# --- Test / coverage ---
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
