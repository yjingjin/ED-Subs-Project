# Copy to .env and fill in. Never commit .env.
# These are placeholders; refine once concrete names are confirmed.

# Databricks scratch catalog + medallion schemas
ED_CATALOG=scratch
ED_BRONZE_SCHEMA=ed_bronze
ED_SILVER_SCHEMA=ed_silver
ED_GOLD_SCHEMA=ed_gold

# Local paths
ED_EXPORT_DIR=data/exports

# MLflow (Phase 3) — on Databricks this is set automatically
MLFLOW_EXPERIMENT=/Users/<you>/ed_subs_churn
