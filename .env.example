# Copy to .env and fill in. Never commit .env.

# Databricks catalog + schema (all medallion tables live in one schema)
ED_CATALOG=general_scratch_catalog
ED_SCHEMA=general_scratch

# Table name prefixes per medallion layer
ED_BRONZE_PREFIX=ed_bronze_
ED_SILVER_PREFIX=ed_silver_
ED_GOLD_PREFIX=ed_gold_

# Local paths
ED_EXPORT_DIR=data/exports

# Databricks Volume: raw CSV upload landing zone
ED_VOLUME_UPLOAD_DIR=/Volumes/general_scratch_catalog/general_scratch/checkpoints/jiny/ed_subs_raw_uploads

# MLflow (Phase 3) — on Databricks this is set automatically
MLFLOW_EXPERIMENT=/Users/yingjin@goodrx.com/ed_subs_churn
